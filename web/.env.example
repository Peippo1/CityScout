# Backend proxy — server-side only, never exposed to the browser.
CITYSCOUT_API_BASE_URL=https://your-render-backend-url.onrender.com
CITYSCOUT_APP_SHARED_SECRET=change_me_for_local_dev

# Supabase — NEXT_PUBLIC_ values are safe to expose to the browser (anon key only).
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
